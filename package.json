{
	"name": "obsidian-lecture-lens",
	"version": "1.0.0",
	"description": "An AI-powered Obsidian assistant for Slides OCR, Course Review, and RAG.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint src/**/*.ts",
		"lint:fix": "eslint src/**/*.ts --fix",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,tsx,js,mjs}": [
			"eslint --fix"
		],
		"*.{json,md}": [
			"prettier --write"
		]
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"ocr",
		"llm",
		"ai",
		"rag",
		"study-tool"
	],
	"author": "Your Name",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"husky": "^9.1.7",
		"jiti": "2.6.1",
		"lint-staged": "^16.2.7",
		"prettier": "^3.7.4",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
