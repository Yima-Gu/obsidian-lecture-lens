{
	"name": "lecture-lens",
	"version": "1.1.0",
	"description": "Turn lecture slides and whiteboard photos into structured notes using Multimodal LLMs.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"pack": "npm run build && node scripts/pack-release.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint src/**/*.ts",
		"lint:fix": "eslint src/**/*.ts --fix",
		"prepare": "husky",
		"test:embedding-prefetch": "node scripts/test-prefetch-download.mjs",
		"test:embedding": "node scripts/test-embedding.mjs"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"ocr",
		"llm",
		"ai",
		"rag",
		"study-tool"
	],
	"author": "Yima Gu",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "14.0.0",
		"husky": "^9.1.7",
		"jiti": "2.6.1",
		"prettier": "^3.7.4",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"@xenova/transformers": "^2.17.2",
		"obsidian": "latest",
		"pdfjs-dist": "^4.10.38"
	}
}
